# pyenv
#   For a library or binary, you wish to ignore their .python-version file.
#   For projects (including web apps), you probably want to check it in.
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to check Pipfile.lock into git.
#   However, in case of collaboration, if having platform-specific dependencies or dependencies
#   having no cross-platform support, pipenv may install dependencies that don't work, or even
#   fail to install of them.
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, it is generally recommended to check poetry.lock in for applications.
#   Stay settled with a clean lock file is helpful for reproducible builds.
#poetry.lock

# pdm
#   Similar to Pipfile.lock, it is generally recommended to check pdm.lock in for applications.
#pdm.lock
#   pdm build tool configuration file
.pdm-python

