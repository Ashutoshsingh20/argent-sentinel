# Core runtime
APP_HOST=0.0.0.0
APP_PORT=8000
TARGET_API=http://host.docker.internal:9000
ENABLE_PHASE5_GATEWAY=1

# Security
JWT_ENABLED=1
JWT_SECRET=change-me
JWT_ALGORITHM=RS256
JWT_ISSUER=argent-sentinel
JWT_AUDIENCE=argent-clients
JWT_ACCESS_TOKEN_MINUTES=10
JWT_PRIVATE_KEY_PEM=
JWT_PUBLIC_KEY_PEM=
JWT_EXEMPT_PATHS=/,/healthz,/metrics,/docs,/openapi.json
JWT_JWKS_URL=
JWT_REQUIRE_HTTPS_FOR_AUTH=1
AUTH_ALLOW_INSECURE_DEV=0
ZT_LOW_TRUST_THRESHOLD=45
ZT_MEDIUM_TRUST_THRESHOLD=65
ZT_HIGH_TRUST_THRESHOLD=85
ZT_DENY_TRUST_THRESHOLD=25
ZT_SESSION_IDLE_TIMEOUT_SECONDS=1800
ZT_STEP_UP_TTL_SECONDS=600
ZT_TOTP_STEP_SECONDS=30
ZT_TOTP_ALLOWED_DRIFT=1
RATE_LIMIT_ENABLED=1
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60

# Redis
REDIS_ENABLED=1
REDIS_URL=redis://redis:6379/0
STATE_KEY_SCOPE=entity
STATE_TTL_NORMAL_SECONDS=86400
STATE_TTL_HIGH_RISK_SECONDS=604800

# Observability
LOG_LEVEL=INFO
LOG_FORMAT=json
PROM_METRICS_ENABLED=1

# HTTPS behavior behind proxy/nginx
FORCE_HTTPS=0

# Cloud integration toggles
CLOUD_ACTIONS_ENABLED=0
AWS_CLOUD_ACTIONS_ENABLED=0
AWS_LAMBDA_TARGET=
AZURE_CLOUD_ACTIONS_ENABLED=0
AZURE_TAG_SCOPE=
GCP_CLOUD_ACTIONS_ENABLED=0
GCP_PROJECT_ID=
CLOUD_ACTIONS_ALLOW_MUTATIONS=0
CLOUD_ACTIONS_TIMEOUT_SECONDS=20
CLOUD_FEATURE_MANIFEST_URLS=
CLOUD_FEATURE_REFRESH_SECONDS=30
